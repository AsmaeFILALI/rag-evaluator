# =========================================================================
# RAG Evaluation Framework — Environment Variables
# =========================================================================
# Copy this file to .env and fill in your values.
# The framework reads these at runtime when credential_type is "key" or "env".
#
# For most development, use `az login` (DefaultAzureCredential) instead.
# =========================================================================

# Azure OpenAI — required when credential_type: key
AZURE_OPENAI_API_KEY=

# Azure AI Foundry — required when credential_type: env (cloud mode)
AZURE_AI_PROJECT_CONNECTION_STRING=
